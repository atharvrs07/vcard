# Copy to .env on the server. Never commit .env with real secrets.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Port the Node process listens on (reverse proxy forwards to this).
PORT=5000

# Optional: set on the host (systemd, PM2, Docker) — Express error handling & caching behavior.
# NODE_ENV=production

# Behind nginx, Caddy, Cloudflare, etc.: trust X-Forwarded-* so HTTPS and host work.
TRUST_PROXY=1

# Max JSON body for POST /save-profile (card profile). Must be <= nginx client_max_body_size.
# JSON_BODY_LIMIT=12mb

# -----------------------------------------------------------------------------
# Public URLs
# -----------------------------------------------------------------------------
# Full base URL of THIS app — the card builder & published cards (no trailing slash).
# Used for profile links, QR codes, and upload URLs when the Host header might not match.
PUBLIC_BASE_URL=https://ecard.xevonet.com

# Optional alias (same as PUBLIC_BASE_URL if you only set one).
# SITE_URL=https://ecard.xevonet.com
# Local development override:
# PUBLIC_BASE_URL=http://localhost:5000
# SITE_URL=http://localhost:5000

# Main marketing / company site (shown in API config; optional for footer links).
MAIN_SITE_URL=https://xevonet.com

# -----------------------------------------------------------------------------
# Razorpay (live keys in production)
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Base price in paise (300000 = ₹3000.00). GST is added on top.
CARD_PRICE_PAISE=300000
GST_PERCENT=18

# NEVER enable in production — local testing only
# ALLOW_INSECURE_PUBLISH=1
